# --- PAI App Configuration ---
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
PRINCIPAL_NAME=User
TIMEZONE=UTC
AI_NAME=PAI
CATCHPHRASE=Ready to go
TEMPERATURE_UNIT=fahrenheit
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Network & Security Configuration ---
# BIND_IP: Default is 127.0.0.1 (Loopback). Set to 0.0.0.0 for public or your VPN IP.
BIND_IP=127.0.0.1
BIND_PORT=8080
VOICE_PORT=8888

# Traefik & VPN Settings
TRAEFIK_ENABLE=false
DOMAIN=localhost
# VPN_SUBNET: Default is 127.0.0.1/32 (Blocked). Set to your WireGuard range (e.g., 10.8.0.0/24).
VPN_SUBNET=127.0.0.1/32
